# Copy to ".env" (in this folder for local dev, or the project root for docker compose) and fill in.
# ── Google Gemini (required for live AI) ──
GEMINI_API_KEY=your-gemini-api-key-here
# Optional: comma-separated model fallback order
GEMINI_MODELS=gemini-2.5-flash,gemini-2.0-flash
# Optional: max output tokens
GEMINI_MAX_TOKENS=1024
# Optional: listen port (default 8090)
PORT=8090
